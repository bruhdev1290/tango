/src/environments/environment.local.ts

# Firebase
.firebase/

# Android
/android/app/build/
/android/.gradle/
/android/build/

# iOS
/ios/App/build/
/ios/App/Pods/
/ios/App/public/
/ios/capacitor-cordova-ios-plugins-sources/
